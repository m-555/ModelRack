# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg
.Python

# ─── Virtual environments ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
# Per-model isolated venvs live inside the models directory
**/.venv/

# ─── Tooling caches ───────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# ─── modelrack runtime state ──────────────────────────────────────────────
.modelrack/
*.processes.json

# ─── Generated inference outputs ──────────────────────────────────────────
outputs/
*.mp4
*.wav

# ─── Model weights (never commit these) ───────────────────────────────────
# Weight *files* are ignored by extension so empty placeholder weights/
# directories (with a .gitkeep) can still be tracked in examples/.
*.safetensors
*.ckpt
*.bin
*.pt
*.pth
*.gguf
*.onnx

# ─── Environment / secrets ────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Local design notes (not part of the public package) ──────────────────
design/

# ─── Editors / OS ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
