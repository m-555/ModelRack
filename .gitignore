# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg
.Python

# ─── Virtual environments ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
# Per-model isolated venvs live inside the models directory
**/.venv/
# Shared venvs (environment.shared_venv) live under <MODELS_DIR>/_shared_venvs/
**/_shared_venvs/
# Model weight caches (HF_HOME) — never commit weights
**/.hf_cache/

# ─── Tooling caches ───────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/

# ─── modelrack runtime state ──────────────────────────────────────────────
.modelrack/
*.processes.json

# ─── Generated inference outputs ──────────────────────────────────────────
outputs/
*.mp4
*.wav

# ─── Model weights (never commit these) ───────────────────────────────────
# Weight *files* are ignored by extension so empty placeholder weights/
# directories (with a .gitkeep) can still be tracked in examples/.
*.safetensors
*.ckpt
*.bin
*.pt
*.pth
*.gguf
*.onnx

# ─── Local models directory (bring-your-own; not versioned) ───────────────
# examples/models is used as the on-disk MODELS_DIR — model definitions, weights,
# venvs, loras and the generated registry.yaml are a local working dir, specific
# to a deployment, and are NOT tracked. Only the placeholder guide is committed.
/examples/models/*
!/examples/models/README.md

# ─── Environment / secrets ────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Local design notes (not part of the public package) ──────────────────
design/

# ─── Editors / OS ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
