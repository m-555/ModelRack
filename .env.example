# ─── modelrack configuration ──────────────────────────────────────────────
# Copy this file to `.env` and adjust the values.

# Absolute path to the centralized models directory (REQUIRED).
# This directory holds one folder per model, plus registry.yaml.
MODELS_DIR=/home/yourname/models

# Port for the hub management REST API (default: 7777).
MODELRACK_PORT=7777

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO).
MODELRACK_LOG_LEVEL=INFO

# Auto-start a model's inference server when infer() is called (default: true).
MODELRACK_AUTO_START=true

# State file tracking running server processes (default: ~/.modelrack/processes.json).
MODELRACK_STATE_FILE=~/.modelrack/processes.json
